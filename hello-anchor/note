# https://solana.com/zh/docs/intro/quick-start/deploying-programs
# 使用本地的test-validator进行部署验证
yxzhang@SolanaLearn:solana-doc$ anchor init hello-anchor --no-git --no-install
yxzhang@SolanaLearn:solana-doc$ cd hello-anchor/
yxzhang@SolanaLearn:hello-anchor$ rm -rf app/ migrations/ .gitignore .prettierignore
yxzhang@SolanaLearn:hello-anchor$ cd programs/hello-anchor/
yxzhang@SolanaLearn:hello-anchor$ rm -rf tests/ src/instructions* src/constants.rs src/error.rs src/state.rs 
yxzhang@SolanaLearn:hello-anchor$ cd -
# 拷贝代码到lib.rs
yxzhang@SolanaLearn:hello-anchor$ anchor build # 生成测试需要的文件
yxzhang@SolanaLearn:hello-anchor$ llvm-readelf -h target/deploy/hello_anchor.so | grep -i flags # 0x0
yxzhang@SolanaLearn:hello-anchor$ cargo build-sbf --arch v3 --manifest-path programs/hello-anchor/Cargo.toml # 针对v3问题的临时方案
yxzhang@SolanaLearn:hello-anchor$ llvm-readelf -h target/deploy/hello_anchor.so | grep -i flags # 0x3
yxzhang@SolanaLearn:hello-anchor$ solana config set --url localhost
yxzhang@SolanaLearn:hello-anchor$ solana program deploy --program-id target/deploy/hello_anchor-keypair.json target/deploy/hello_anchor.so 
yxzhang@SolanaLearn:hello-anchor$ mkdir tests
yxzhang@SolanaLearn:hello-anchor$ touch tests/hello_anchor_test.ts # 拷贝代码，进行必要修改
yxzhang@SolanaLearn:hello-anchor$ yarn
yxzhang@SolanaLearn:hello-anchor$ anchor test
yxzhang@SolanaLearn:hello-anchor$ solana confirm -v 2s7dBfDFBQnTozww2jdiS9i5zUMywnnfqmtSem3jYErCKAt59BHCETfSyrATG9RDgParc55QBPBm8m52FxWoBgn8
